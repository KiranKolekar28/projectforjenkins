pipeline{
    agent any
    
    stages{
        stage("git clone"){
            steps{
                echo "We are going to clone "
                git url: "https://github.com/KiranKolekar28/projectforjenkins.git", branch: "master"
            }
        }
        
        stage("Image build"){
            steps{
                echo "We will create image from Dockerfile"
                sh "docker build -t insect:latest . "
            }
        }
        
        stage("Pushing image to the Dockerhub"){
            steps{
                echo " lets push image to the docker hub"
                withCredentials([usernamePassword('credentialsId':"DockerHubCred" ,
                passwordVariable:"dockerHubPass" , 
                usernameVariable:"dockerHubUser")]){
                sh "docker login -u ${env.dockerHubUser} -p ${env.dockerHubPass} "
                sh "docker tag insect:latest ${env.dockerHubUser}/insect:latest "
                sh "docker push ${env.dockerHubUser}/insect:latest"
                }
            }
        }
        
        
        stage("deploy"){
            steps{
                echo "We will deploye image now"
                
                sh "docker-compose up -d"
            }
        }
        
        
        
        
    }
    
    
}