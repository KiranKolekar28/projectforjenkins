// New Way 


@Library("shared") _

pipeline{
    agent any
    
    stages{

        stage("git clone"){
            steps{
                echo "We are going to clone "
                script{
                     clone( "https://github.com/KiranKolekar28/projectforjenkins.git","master" )
                }
                
            }
        }
        
        stage("Image build"){
            steps{
                script{
                    
                      dockers_build("insects" , "latest")
                }              
            }
        }
        
        stage("Pushing image to the Dockerhub"){
            steps{
                script{
                    docker_push("insect" , "latest")
                }
            }
        }
        
        stage("deploy"){
            steps{
                script{
                    Docker_deploy()
                }
                
            }
        }   
    }
}